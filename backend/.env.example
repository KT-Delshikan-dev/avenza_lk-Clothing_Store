PORT=5005
NODE_ENV=development

# Appwrite Configuration
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_server_api_key
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_COLLECTION_PRODUCTS=products
APPWRITE_COLLECTION_USERS=users
APPWRITE_COLLECTION_ORDERS=orders
APPWRITE_COLLECTION_PAYMENT=payment
APPWRITE_STORAGE_BUCKET_ID=your_storage_bucket_id

JWT_SECRET=change_this_in_production
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=31457280

# Local development: http://localhost:3000
# Production: https://clothing-store-e3s.pages.dev
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra origins, for example:
# FRONTEND_URLS=https://clothing-store-e3s.pages.dev,https://c7df296a.clothing-store-e3s.pages.dev

ML_SERVICE_URL=http://localhost:8000
TWILIO_ACCOUNT_SID=mock_twilio_sid
TWILIO_AUTH_TOKEN=mock_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
STRIPE_SECRET_KEY=mock_stripe_key
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=mock_user
EMAIL_PASS=mock_pass
EMAIL_FROM=no-reply@avenza.lk
